# Supabase 설정
# Supabase 대시보드 → Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (서버 전용 - 절대 NEXT_PUBLIC_ 붙이지 말 것)
# Supabase 대시보드 → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend API Key (이메일 발송)
# https://resend.com 에서 발급
RESEND_API_KEY=re_your-resend-key-here

# 발신 이메일 주소 (Resend에서 인증한 도메인)
RESEND_FROM_EMAIL=noreply@locals.kr

# Upstash Redis (API Rate Limiting)
# https://upstash.com → Redis 데이터베이스 생성 → REST API 탭에서 확인
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here
